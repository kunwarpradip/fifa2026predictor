rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    match /admins/{uid} { allow read: if signedIn(); allow write: if isAdmin(); }
    match /users/{uid} { allow read: if signedIn(); allow create, update: if isOwner(uid); }
    match /matches/{matchId} { allow read: if signedIn(); allow write: if isAdmin(); }
    match /predictions/{predictionId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.matchId is string;
    }
  }
}
